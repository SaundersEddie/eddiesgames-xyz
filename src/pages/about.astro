---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="about">
    <h1>About Eddies Games</h1>

    <p>
      eddiesgames.xyz is a collection of lightweight browser games designed to be quick to load, easy to play, and accessible on both desktop and mobile devices.
    </p>

    <p>
      The goal is simple: create fast, focused games without unnecessary downloads, accounts, or interruptions to gameplay. Each game is built to be picked up quickly and played in short sessions.
    </p>

    <p>
      New games are added regularly as part of an ongoing effort to improve mechanics, refine design, and keep the experience clean and responsive.
    </p>

    <h2>Tech Stack</h2>
    <ul>
      <li>Astro (site framework)</li>
      <li>Vanilla JavaScript</li>
      <li>HTML5 Canvas (where needed)</li>
      <li>Cloudflare (hosting + DNS)</li>
    </ul>

    <h2>Assets & Credits</h2>
    <p>
      Some sound effects and assets are sourced from
      <a href="https://kenney.nl" target="_blank" rel="noopener">Kenney.nl</a>.
    </p>

    <h2>Contact</h2>
    <p>
      For questions or feedback:
      <br />
      <a href="mailto:eddie@eddiesgames.xyz">
        eddie@eddiesgames.xyz
      </a>
    </p>

    <p class="note">
      This site may include advertising to help support hosting and ongoing development.
    </p>
  </section>
</BaseLayout>

<style>
.about {
  max-width: 800px;
  margin: 0 auto;
  display: grid;
  gap: 20px;
}

h1 {
  margin-top: 0;
}

h2 {
  margin-top: 24px;
}

ul {
  padding-left: 20px;
  color: var(--muted);
}

.note {
  font-size: 0.85rem;
  color: var(--muted);
  opacity: 0.8;
}
</style>
