---
const { position } = Astro.props;

// Only bottom is supported. Keep placeholders OFF by default.
const SHOW_AD_PLACEHOLDERS = false;
---

{position === "bottom" && SHOW_AD_PLACEHOLDERS && (
  <div class="ad ad-bottom">
    <div class="ad-inner"></div>
  </div>
)}

<style>
.ad {
  display: flex;
  justify-content: center;
  padding: 12px 0;
}

/* Ad container (empty by default) */
.ad-inner {
  width: 100%;
  max-width: 728px;
  height: 90px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px dashed var(--line);
  border-radius: 12px;
}
</style>